    "open-government",
    "betanyc",
    "311",
    "nyc-311",
    "alternate-side-parking",
    "service-request",
    "city-services"
  ],
  "license": "MIT",
  "author": "BetaNYC",
  "homepage": "https://github.com/BetaNYC/nyc-311-mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BetaNYC/nyc-311-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/BetaNYC/nyc-311-mcp/issues"
  },
  "type": "module",
  "main": "dist/index.js",
